# Backend Config
PROJECT_NAME="FindER API"
VERSION="1.0.0"
API_V1_STR="/api/v1"
SECRET_KEY="replace-with-secure-aes-256-key-in-prod"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
POSTGRES_SERVER="db"
POSTGRES_USER="finder_user"
POSTGRES_PASSWORD="finder_password"
POSTGRES_DB="finder_db"
POSTGRES_PORT=5432
DATABASE_URL="postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}"

# Redis
REDIS_URL="redis://redis:6379/0"

# Security
CORS_ORIGINS="http://localhost:3000,https://finder.app"
